# PreMortem configuration. Copy to .env. Mock mode needs NOTHING set.

# Provider: "mock" (deterministic, creds-free — default) or "dashscope" (real Qwen Cloud).
PREMORTEM_LLM=mock

# --- Only required when PREMORTEM_LLM=dashscope ---
# DashScope (Qwen Cloud) API key. Obtained from the Alibaba Cloud / Qwen Cloud console.
# NEVER commit a real key. See ~/.credentials/ for storage convention.
DASHSCOPE_API_KEY=
# OpenAI-compatible base URL for DashScope (international endpoint):
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Models
PREMORTEM_REASONING_MODEL=qwen-max
PREMORTEM_VISION_MODEL=qwen-vl-max

# Engine knobs
PREMORTEM_SELF_CONSISTENCY_N=5
PREMORTEM_MEMORY_DB=premortem_memory.sqlite3
